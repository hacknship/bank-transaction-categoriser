{
  "manifest_version": 3,
  "name": "Maybank Budget Tracker",
  "version": "1.0.0",
  "description": "Categorize Maybank transactions with budget tracking",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.maybank2u.com.my/*", "https://*.maybank2u.com.my/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["data-viewer.html", "data-viewer.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
